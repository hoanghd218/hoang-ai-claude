# ============================================
# KDP Coloring Book Generator - Local Config
# ============================================
# Copy this file to .env and fill in your own values.
# Never commit .env to git.

# ---- Image Renderer Selection ----
# Options: ai33 | bimai | kie | nanopic
IMAGE_RENDERER=ai33

# ---- API Keys (fill in the renderer you use) ----
AI33_KEY=
BIMAI_API_KEY=
KIE_API_KEY=

# NanoPic — supports multiple tokens separated by commas for round-robin
NANOPIC_ACCESS_TOKEN=
NANOPIC_API_KEY=

# ---- Author Info (shown on cover + title page + copyright) ----
AUTHOR_FIRST_NAME=Tony
AUTHOR_LAST_NAME=Hoang
